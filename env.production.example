# ══════════════════════════════════════════════════════════════
#  TopUpPay — Production Environment Variables
#  Copy this file to .env.production and fill in REAL values
#  NEVER commit .env.production to git
# ══════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────
DB_USER=topuppay
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_32CHARS
DB_NAME=topuppay_prod

# ─── Backend ──────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
JWT_SECRET=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_STRING
ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
AUDIT_KEY=OPTIONAL_SECRET_FOR_BYPASSING_RATE_LIMITS

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://YOUR_DOMAIN.com,https://www.YOUR_DOMAIN.com

# ─── Frontend ─────────────────────────────────────────────────
# This must be the PUBLIC URL of your backend API (via Nginx)
NEXT_PUBLIC_API_URL=https://YOUR_DOMAIN.com/api

# ─── Bakong KHQR (PRODUCTION — get from NBC Cambodia) ─────────
# Apply at: https://bakong.nbc.org.kh/
BAKONG_ACCOUNT_ID=yourname@yourbank
BAKONG_MERCHANT_NAME=TopUpPay Co., Ltd.
BAKONG_MERCHANT_CITY=Phnom Penh
BAKONG_ACQUIRING_BANK=ABA Bank

# Digiflazz (Popular SEA Aggregator — http://digiflazz.com)
DIGIFLAZZ_USERNAME=your_username
DIGIFLAZZ_API_KEY=your_production_api_key
# UniPin (Alternative — https://unipin.com)
UNIPIN_PARTNER_ID=your_partner_id
UNIPIN_SECRET_KEY=your_secret_key

# ─── Cloudflare Tunnel ────────────────────────────────────────
# Get this from Cloudflare Zero Trust Dashboard
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# ─── Optional: Monitoring & Alerting ──────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/xxx
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
