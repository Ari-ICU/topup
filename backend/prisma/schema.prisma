generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String?       @unique
  name         String?
  createdAt    DateTime      @default(now())
  transactions Transaction[]
}

model Game {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  iconUrl     String?
  bannerUrl   String?
  inputConfig Json
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  sortOrder   Int       @default(0)
  packages    Package[]
}

model Package {
  id           String        @id @default(cuid())
  gameId       String
  name         String
  amount       Int
  price        Decimal       @db.Decimal(10, 2)
  providerSku  String
  description  String?
  badgeText    String?
  isWeeklyPass Boolean       @default(false)
  sortOrder    Int           @default(0)
  game         Game          @relation(fields: [gameId], references: [id])
  transactions Transaction[]
}

model GlobalStock {
  id                      String   @id @default("GLOBAL")
  diamonds                Int      @default(0)
  providerBalance         Decimal  @default(0) @db.Decimal(10, 2)
  totalTransferredRevenue Decimal  @default(0) @db.Decimal(10, 2)
  updatedAt               DateTime @updatedAt
}

model Transaction {
  id            String            @id @default(cuid())
  userId        String?
  packageId     String
  status        TransactionStatus @default(PENDING)
  paymentMethod String
  paymentRef    String?           @unique
  providerRef   String?           @unique
  playerInfo    Json
  totalAmount   Decimal           @db.Decimal(10, 2)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  package       Package           @relation(fields: [packageId], references: [id])
  user          User?             @relation(fields: [userId], references: [id])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Promotion {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?
  badgeText   String?
  badgeColor  String   @default("purple")
  imageUrl    String
  linkUrl     String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  EXPIRED
}

model Reseller {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  userId    String   @unique
  partnerId String   @unique
  secretKey String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
